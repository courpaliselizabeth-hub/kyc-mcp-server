# ============================================================
# KYC MCP Server — Environment Variables
# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit real API keys.
# ============================================================

# ── Banking / Compliance API credentials ─────────────────────
# Primary banking API (document blacklist, watchlist, etc.)
BANKING_API_KEY=your_banking_api_key_here
BANKING_API_BASE_URL=https://api.banking.example.com/

# Identity verification provider (e.g. Jumio, Onfido, Trulioo)
IDENTITY_VERIFICATION_API_KEY=your_identity_api_key_here
IDENTITY_VERIFICATION_API_BASE_URL=https://api.identity.example.com/

# Document verification provider (e.g. Mitek, Acuant)
DOCUMENT_VERIFICATION_API_KEY=your_document_api_key_here
DOCUMENT_VERIFICATION_API_BASE_URL=https://api.documents.example.com/

# AML / sanctions screening provider (e.g. LexisNexis, Dow Jones)
AML_API_KEY=your_aml_api_key_here
AML_API_BASE_URL=https://api.aml.example.com/

# ── Server behaviour ─────────────────────────────────────────
# Timeout in seconds for external API calls (default: 30)
REQUEST_TIMEOUT_SECONDS=30

# Show full exception details in error responses (true in dev, false in prod)
ENABLE_DETAILED_ERRORS=false

# ASP.NET Core environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development

# Port the server listens on
ASPNETCORE_URLS=http://localhost:5000
