{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "BankingApiKey": "",
    "BankingApiBaseUrl": "https://api.banking.example.com/",
    "IdentityVerificationApiKey": "",
    "IdentityVerificationApiBaseUrl": "https://api.identity.example.com/",
    "DocumentVerificationApiKey": "",
    "DocumentVerificationApiBaseUrl": "https://api.documents.example.com/",
    "AmlApiKey": "",
    "AmlApiBaseUrl": "https://api.aml.example.com/",
    "RequestTimeoutSeconds": 30,
    "EnableDetailedErrors": false,
    "McpServerVersion": "1.0.0"
  }
}
